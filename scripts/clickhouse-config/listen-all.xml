<!--
  Replace ClickHouse's default loopback-only listen_host with a
  wildcard so the server accepts connections forwarded by Docker's
  port mapping.

  ClickHouse 24.8's stock config binds to 127.0.0.1 first and then
  tries to add 0.0.0.0 from docker_related_config.xml. The second
  bind fails with EADDRINUSE because the kernel won't let 0.0.0.0
  overlap an already-bound specific address — the server ends up
  listening only on the container's loopback, which Docker's port
  mapping can't reach.

  ``replace="replace"`` is ClickHouse's XML-merge directive that
  drops every other ``<listen_host>`` from the merged tree, leaving
  this one as the sole entry.
-->
<clickhouse>
    <listen_host replace="replace">0.0.0.0</listen_host>
</clickhouse>
